{
  "id": null,
  "uid": "traces-overview",
  "title": "Traces Overview",
  "tags": ["otel", "clickhouse", "traces"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 6,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Total Spans (last 1h)",
      "description": "Total number of spans ingested in the last hour.",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT count() AS spans FROM otel.otel_traces WHERE Timestamp >= now() - INTERVAL 1 HOUR",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value", "graphMode": "none", "textMode": "auto" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error Spans (last 1h)",
      "description": "Count of spans marked with error status in the last hour.",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT countIf(StatusCode = 'Error') AS errors FROM otel.otel_traces WHERE Timestamp >= now() - INTERVAL 1 HOUR",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Error Rate % (last 1h)",
      "description": "Percentage of spans with error status out of total spans.",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT round(100.0 * countIf(StatusCode = 'Error') / greatest(count(), 1), 2) AS error_rate_pct FROM otel.otel_traces WHERE Timestamp >= now() - INTERVAL 1 HOUR",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 5 }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Avg Span Duration (last 1h)",
      "description": "Mean span duration in milliseconds across all spans in the last hour.",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT round(avg(Duration) / 1e6, 2) AS avg_ms FROM otel.otel_traces WHERE Timestamp >= now() - INTERVAL 1 HOUR",
          "format": 0,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 1000 }]
          }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Spans per minute — OK vs Error",
      "description": "Per-minute span throughput split by status class.",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT toStartOfMinute(Timestamp) AS time, countIf(StatusCode = 'Ok') AS ok, countIf(StatusCode = 'Error') AS error, countIf(StatusCode = 'Unset') AS unset FROM otel.otel_traces WHERE Timestamp >= now() - INTERVAL 1 HOUR GROUP BY time ORDER BY time",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "error" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "ok" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Avg Span Duration per minute (ms)",
      "description": "Per-minute latency trend with average and P95 span duration.",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 4 },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT toStartOfMinute(Timestamp) AS time, round(avg(Duration) / 1e6, 2) AS avg_ms, round(quantile(0.95)(Duration) / 1e6, 2) AS p95_ms FROM otel.otel_traces WHERE Timestamp >= now() - INTERVAL 1 HOUR GROUP BY time ORDER BY time",
          "format": 1,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ms" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "p95_ms" }, "properties": [{ "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } }] }
        ]
      },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Spans by Status (last 1h)",
      "description": "Share of spans by trace status code for the last hour.",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 9, "w": 8, "x": 0, "y": 13 },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT countIf(StatusCode = 'Ok') AS Ok, countIf(StatusCode = 'Error') AS Error, countIf(StatusCode = 'Unset') AS Unset FROM otel.otel_traces WHERE Timestamp >= now() - INTERVAL 1 HOUR",
          "format": 0,
          "refId": "A"
        }
      ],
      "options": { "legend": { "displayMode": "list", "placement": "right" }, "tooltip": { "mode": "single" } },
      "fieldConfig": { "defaults": {}, "overrides": [] }
    },
    {
      "id": 8,
      "type": "table",
      "title": "Top Operations (last 1h)",
      "description": "Operations ranked by span volume with latency and error counts.",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 9, "w": 16, "x": 8, "y": 13 },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT SpanName AS operation, count() AS total_spans, round(avg(Duration) / 1e6, 2) AS avg_ms, round(quantile(0.95)(Duration) / 1e6, 2) AS p95_ms, round(max(Duration) / 1e6, 2) AS max_ms, countIf(StatusCode = 'Error') AS errors FROM otel.otel_traces WHERE Timestamp >= now() - INTERVAL 1 HOUR GROUP BY operation ORDER BY total_spans DESC LIMIT 20",
          "format": 0,
          "refId": "A"
        }
      ],
      "options": { "showHeader": true, "footer": { "show": false } },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "avg_ms" }, "properties": [{ "id": "unit", "value": "ms" }] },
          { "matcher": { "id": "byName", "options": "p95_ms" }, "properties": [{ "id": "unit", "value": "ms" }] },
          { "matcher": { "id": "byName", "options": "max_ms" }, "properties": [{ "id": "unit", "value": "ms" }] },
          { "matcher": { "id": "byName", "options": "errors" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "transparent", "value": null }, { "color": "red", "value": 1 }] } }] }
        ]
      }
    },
    {
      "id": 9,
      "type": "table",
      "title": "Slow Spans >50ms (last 1h)",
      "description": "Slowest spans above 50ms with route, status, and trace correlation context.",
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "clickhouse" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "queryType": "sql",
          "rawSql": "SELECT formatDateTime(Timestamp, '%Y-%m-%d %H:%i:%s') AS timestamp, SpanName AS operation, round(Duration / 1e6, 2) AS duration_ms, StatusCode AS status, SpanAttributes['http.status_code'] AS http_status, SpanAttributes['http.method'] AS method, SpanAttributes['http.route'] AS route, SpanAttributes['user.id'] AS user_id, SpanAttributes['leaderboard.entries.count'] AS entries, TraceId AS trace_id FROM otel.otel_traces WHERE Timestamp >= now() - INTERVAL 1 HOUR AND Duration >= 50000000 ORDER BY Duration DESC LIMIT 50",
          "format": 0,
          "refId": "A"
        }
      ],
      "options": { "showHeader": true, "footer": { "show": false } },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          { "matcher": { "id": "byName", "options": "duration_ms" }, "properties": [{ "id": "unit", "value": "ms" }, { "id": "custom.displayMode", "value": "color-background" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 200 }, { "color": "red", "value": 1000 }] } }] },
          { "matcher": { "id": "byName", "options": "status" }, "properties": [{ "id": "custom.displayMode", "value": "color-background" }, { "id": "mappings", "value": [{ "type": "value", "options": { "Error": { "color": "red", "index": 0 }, "Ok": { "color": "green", "index": 1 } } }] }] }
        ]
      }
    }
  ],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  }
}
