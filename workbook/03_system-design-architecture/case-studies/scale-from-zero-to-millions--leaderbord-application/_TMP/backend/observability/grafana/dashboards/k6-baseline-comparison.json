    {
      "id": 21,
      "type": "stat",
      "title": "Delta p95 (B2 vs B1) %",
      "description": "Relative change in average p95 latency over selected time range. Negative is better.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "100 * (avg_over_time(k6_http_req_duration_p95{baseline_label=\"$baseline_label_2\",test_profile=\"$test_profile\"}[$__range]) - avg_over_time(k6_http_req_duration_p95{baseline_label=\"$baseline_label_1\",test_profile=\"$test_profile\"}[$__range])) / clamp_min(avg_over_time(k6_http_req_duration_p95{baseline_label=\"$baseline_label_1\",test_profile=\"$test_profile\"}[$__range]), 0.001)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "value",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      }
    },
    {
