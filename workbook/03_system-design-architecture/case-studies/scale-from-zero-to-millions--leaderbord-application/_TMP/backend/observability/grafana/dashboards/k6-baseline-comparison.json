          "expr": "100 * ((increase(k6_http_reqs_total{baseline_label=\"$baseline_label_2\",test_profile=\"$test_profile\"}[$__range]) / $__range_s) - (increase(k6_http_reqs_total{baseline_label=\"$baseline_label_1\",test_profile=\"$test_profile\"}[$__range]) / $__range_s)) / clamp_min((increase(k6_http_reqs_total{baseline_label=\"$baseline_label_1\",test_profile=\"$test_profile\"}[$__range]) / $__range_s), 0.001)",
          "refId": "A"
